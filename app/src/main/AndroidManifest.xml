<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk tools:overrideLibrary="top.yukonga.miuix.kmp.blur" />

    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="PackageVisibilityPolicy" />
    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="com.oplus.systemui.plugins" />
    </queries>

    <application
        android:name=".LyriconApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:description="@string/app_description"
        android:theme="@style/Theme.DayNight">

        <activity
            android:name=".activity.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SplashScreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.AboutActivity"
            android:label="@string/activity_about" />

        <activity
            android:name=".activity.SettingsActivity"
            android:label="@string/activity_settings" />

        <activity
            android:name=".activity.LicensesActivity"
            android:label="@string/activity_open_source_licenses" />

        <activity
            android:name=".activity.lyric.BasicLyricStyleActivity"
            android:label="@string/activity_basic_settings" />

        <activity
            android:name=".activity.lyric.pkg.PackageStyleActivity"
            android:label="@string/activity_app_style_manager" />

        <activity
            android:name=".activity.lyric.provider.LyricProviderActivity"
            android:label="@string/activity_lyric_provider_services" />

        <activity
            android:name=".activity.lyric.AnchorViewTreeActivity"
            android:label="@string/activity_anchor" />

        <activity
            android:name=".activity.lyric.ViewRulesTreeActivity"
            android:label="@string/activity_view_rules" />

    </application>

</manifest>
